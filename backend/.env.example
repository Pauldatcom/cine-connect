# Backend Environment Variables
# Copy this file to .env and fill in real values

# Server
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/cineconnect

# JWT Authentication (min 32 characters for secret)
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
FRONTEND_URL=http://localhost:5173


GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# E2E tests (Playwright): password used to register test users in chat + user-public-profile specs
E2E_TEST_PASSWORD=

# TMDb API (optional - get key from https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your-tmdb-api-key
