# Frontend Environment Variables
# Copy this file to .env and fill in real values.

# Backend API base URL (auth, films, reviews, and TMDb JSON proxy /api/v1/tmdb)
VITE_API_URL=http://localhost:3000
# Vercel: set VITE_API_URL in Project → Settings → Environment Variables (Production + Preview).
# Use your Cloud Run API HTTPS URL, no trailing slash. Rebuild after changing it.

# TMDb: set TMDB_API_KEY in backend/.env only — never in the frontend.
